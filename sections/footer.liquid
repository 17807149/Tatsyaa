{% comment %}
  Tatsyaa Footer Section
  -------------------------------------------------------------
  Description: Displays a high-fidelity editorial footer with social, quicklinks, support directories, and payment trust seals matching the Tatsyaa Modern Heritage design board.
  Dependencies:
    - Tailwind CSS
    - Google Fonts (Noto Serif, Manrope)
    - Material Symbols
  How to use:
    - Add to page footer-group. Configure Quicklinks menu lists in the schema panel.
{% endcomment %}

<footer class="bg-surface-container-low dark:bg-surface-container-lowest w-full py-16 border-t border-outline-variant dark:border-outline full-width">
  
  {% # Top Directory Links %}
  <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter px-margin-desktop max-w-container-max mx-auto">
    
    {% # Column 1: Brand Info & Socials %}
    <div class="col-span-1 md:col-span-2">
      <div class="mb-6">
        <a class="block leading-none select-none" href="{{ routes.root_url }}">
          <img 
            src="{{ 'tatsyaa-logo.png' | asset_url }}" 
            alt="Tatsyaa" 
            width="120" 
            height="48"
            class="h-10 w-auto object-contain"
          />
        </a>
      </div>
      <p class="text-body-md text-on-surface-variant max-w-md mb-8">
        Curating India's Finest Homegrown Designers. Bringing the soul of traditional Indian craftsmanship to the contemporary global stage.
      </p>
      
      {% # Social Accents %}
      <div class="flex gap-6">
        <a class="text-secondary hover:text-primary transition-colors" href="#" aria-label="Pinterest">
          <span class="material-symbols-outlined">social_leaderboard</span>
        </a>
        <a class="text-secondary hover:text-primary transition-colors" href="#" aria-label="Instagram">
          <span class="material-symbols-outlined">camera</span>
        </a>
        <a class="text-secondary hover:text-primary transition-colors" href="#" aria-label="Contact Email">
          <span class="material-symbols-outlined">alternate_email</span>
        </a>
      </div>
    </div>

    {% # Column 2: Explore Quicklinks %}
    <div>
      <h3 class="text-label-md font-label-md uppercase tracking-widest text-primary mb-6">Explore</h3>
      <ul class="space-y-4">
        {% for link in section.settings.explore_menu.links %}
          <li>
            <a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="{{ link.url }}">
              {{ link.title }}
            </a>
          </li>
        {% else %}
          <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="/collections/new-arrivals">New Arrivals</a></li>
          <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="/collections/all">Collections</a></li>
          <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="/collections/handloom">Handloom Specials</a></li>
          <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="/pages/about-us">About Us</a></li>
        {% endfor %}
      </ul>
    </div>

    {% # Column 3: Support Quicklinks %}
    <div>
      <h3 class="text-label-md font-label-md uppercase tracking-widest text-primary mb-6">Support</h3>
      <ul class="space-y-4">
        {% for link in section.settings.support_menu.links %}
          <li>
            <a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="{{ link.url }}">
              {{ link.title }}
            </a>
          </li>
        {% else %}
          <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="/pages/contact">Contact Us</a></li>
          <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="/pages/shipping-returns">Shipping & Returns</a></li>
          <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="/pages/privacy-policy">Privacy Policy</a></li>
          <li><a class="text-on-surface-variant hover:text-primary hover:translate-x-1 transition-all duration-300 block text-body-md" href="/pages/terms">Terms of Service</a></li>
        {% endfor %}
      </ul>
    </div>

  </div>

  {% # Bottom Copyright Bar %}
  <div class="px-margin-desktop max-w-container-max mx-auto mt-16 pt-8 border-t border-outline-variant/30 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="text-label-md text-on-surface-variant/70">
      &copy; {{ 'now' | date: '%Y' }} Tatsyaa. All Rights Reserved.
    </p>
    
    <div class="flex gap-8 items-center text-label-md text-on-surface-variant/70">
      <span>Made with love in India</span>
      
      {% # Payment & Trust Seals %}
      <div class="flex gap-4">
        <span class="material-symbols-outlined text-[18px]" title="Secure Payments">payments</span>
        <span class="material-symbols-outlined text-[18px]" title="Verified Safe">verified_user</span>
      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Tatsyaa Footer Group",
  "settings": [
    {
      "type": "link_list",
      "id": "explore_menu",
      "label": "Explore Navigation Menu"
    },
    {
      "type": "link_list",
      "id": "support_menu",
      "label": "Support Navigation Menu"
    }
  ]
}
{% endschema %}
