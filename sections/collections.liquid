<!-- Vanilla JS Filter Controller -->
<script>
  function filterCollections(category) {
    const cards = document.querySelectorAll('.collection-card-item');
    const buttons = document.querySelectorAll('.filter-tab-btn');

    // 1. Reset buttons styling to inactive state
    buttons.forEach(btn => {
      btn.className = "filter-tab-btn px-5 py-2.5 rounded-lg text-[11px] font-bold uppercase tracking-widest bg-white text-[#5c5e68] border border-neutral-200 hover:border-[#5a000c] hover:text-[#5a000c] transition-all duration-300";
    });

    // 2. Set active button styling
    const activeBtn = document.getElementById(`btn-${category}`);
    if (activeBtn) {
      activeBtn.className = "filter-tab-btn px-5 py-2.5 rounded-lg text-[11px] font-bold uppercase tracking-widest bg-[#5a000c] text-white border border-[#5a000c] transition-all duration-300";
    }

    // 3. Smooth fade hide / display card items
    cards.forEach(card => {
      const cardCat = card.getAttribute('data-category');
      
      if (category === 'all' || cardCat === category) {
        card.style.display = 'flex';
        // Force reflow for fade animation
        setTimeout(() => {
          card.style.opacity = '1';
          card.style.transform = 'scale(1)';
        }, 50);
      } else {
        card.style.opacity = '0';
        card.style.transform = 'scale(0.95)';
        setTimeout(() => {
          card.style.display = 'none';
        }, 300);
      }
    });
  }
</script>

