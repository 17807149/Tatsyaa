  </section>

  {% # 5. Customer Reviews Panel %}
  <section class="mt-32 border-t border-neutral-100 pt-20">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4">
      <div>
        <h3 class="text-headline-lg font-normal text-[#5a000c]" style="font-family: 'Noto Serif', serif; text-transform: none;">Reviews</h3>
        <div class="flex items-center space-x-2 mt-3" style="font-family: 'Manrope', sans-serif;">
          <div class="flex text-[#5a000c]">
            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 0.5;">star_half</span>
          </div>
          <span class="text-body-md text-neutral-800 font-bold">4.8 <span class="text-neutral-400 font-normal">(124 reviews)</span></span>
        </div>
      </div>
      <button type="button" class="px-6 py-3 border border-[#5a000c] text-[#5a000c] font-bold text-[12px] uppercase tracking-wider hover:bg-[#5a000c] hover:text-white transition-all rounded-lg" style="font-family: 'Manrope', sans-serif;">
        Write a Review
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
      
      {% # Review Card 1 %}
      <div class="p-8 bg-[#fbf8ff] border border-neutral-100 rounded-lg flex flex-col justify-between space-y-6">
        <div>
          <div class="flex text-[#5a000c] mb-4">
            <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
