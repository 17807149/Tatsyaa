{% comment %}
  Tatsyaa Luxury Editorial Product Detail Section
  -------------------------------------------------------------
  Description: A high-fidelity, premium product detail page styled according to the modern heritage aesthetic.
  Features:
    - Beautiful breadcrumb navigation.
    - Two-column horizontal bento layout: Left bento grid gallery, right sticky purchase details.
    - Dynamic Shopify form integrating variants, select options, and pricing with automatic luxury fallbacks.
    - Interactive "Details", "Care", and "Shipping" editorial tab-swappers.
    - "Styled by You" responsive social proof gallery.
    - Customer reviews panel with premium rating cards.
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign compare_at_price = current_variant.compare_at_price
  assign price = current_variant.price
  assign is_discounted = false
  
  if compare_at_price > price
    assign is_discounted = true
    assign discount_diff = compare_at_price | minus: price
    assign discount_percent = discount_diff | times: 100 | divided_by: compare_at_price
  endif
-%}

<style>
  .active-tab {
    border-bottom: 2px solid #5a000c;
    color: #5a000c;
  }
  .pattern-bg {
    background-image: radial-gradient(#dfbfbd 0.5px, transparent 0.5px);
    background-size: 24px 24px;
    opacity: 0.2;
  }
  .tab-content-block {
    display: none;
    animation: fadeIn 0.4s ease-out forwards;
  }
  .tab-content-block.active {
    display: block;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<section class="w-full bg-white py-8 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto full-width" id="TatsyaaProductSection">
  
  {% # 1. Breadcrumbs %}
  <nav class="w-full mb-8" aria-label="Breadcrumbs">
    <ol class="flex items-center space-x-2 text-[11px] font-bold uppercase tracking-wider text-secondary">
      <li><a class="hover:text-[#5a000c] transition-colors" href="{{ routes.root_url }}">Home</a></li>
      <li class="material-symbols-outlined text-[14px] text-neutral-400 select-none">chevron_right</li>
      <li><a class="hover:text-[#5a000c] transition-colors" href="/collections/all">Collections</a></li>
      <li class="material-symbols-outlined text-[14px] text-neutral-400 select-none">chevron_right</li>
      <li class="text-[#5a000c] truncate">
        {% if product.title != blank %}{{ product.title }}{% else %}Lace Detail Handloom Co-ord Set{% endif %}
      </li>
    </ol>
  </nav>

  {% # 2. Main Product Section Grid %}
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start">
    
    {% # Left Side: Main Gallery (Bento Style Layout) %}
    <div class="lg:col-span-7 grid grid-cols-2 gap-4">
      
      {% # 2a. Main Hero Image Card %}
      <div class="col-span-2 relative group aspect-[3/4] overflow-hidden bg-neutral-50 rounded-lg border border-neutral-100">
        {% if product.featured_image != blank %}
          <img 
            id="TatsyaaMainImage"
            src="{{ product.featured_image | image_url: width: 900 }}" 
            alt="{{ product.title | escape }}" 
            width="900"
            height="1200"
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
          />
        {% else %}
          {% # High-Fidelity Fallback Image %}
          <img 
            id="TatsyaaMainImage"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuAwrZkkmbCO26nbS_Elf1iGNGJbGWXAF9zK1wTVRwmKt7EwXYKQVMsLeLSTBxYjXxCpFa405EAMaPWoEVkrgpJtLq48kNdsskEcNKNQ7wLF6k2LCIE7OD7S8BzU33lqp5GmLC9CbDsEvDmoye3EwPE2rROTP5lfPqNKFNkrVkhBuKQvRmb4mzvMXc_KKWcYXZfwvrMvdJXZyVCMhXlsEdUnprl97gKhvLJtI3tWkNvuBeXa-h_r00keJJnK-jYCRpG-vdkqFHCNCt4A" 
            alt="Lace Detail Handloom Co-ord Set" 
            width="900"
            height="1200"
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
          />
        {% endif %}
        
        {% # Subtle Interactive Color Overlay Toggle (Fidelity Mock) %}
        <div class="absolute bottom-6 left-6 flex space-x-3 bg-white/80 backdrop-blur px-4 py-2.5 rounded-full border border-white">
          <button class="w-6 h-6 border border-neutral-300 rounded-full bg-[#f4e04d] hover:scale-110 transition-transform cursor-pointer" aria-label="Sunflower Yellow" onclick="changeColor('yellow', this)"></button>
          <button class="w-6 h-6 border border-neutral-300 rounded-full bg-[#d26c8b] hover:scale-110 transition-transform cursor-pointer" aria-label="Vintage Rose" onclick="changeColor('pink', this)"></button>
          <button class="w-6 h-6 border border-neutral-300 rounded-full bg-[#f5f5dc] hover:scale-110 transition-transform cursor-pointer" aria-label="Pristine Cream" onclick="changeColor('cream', this)"></button>
        </div>
      </div>

      {% # 2b. Bento Detail Image 1 (Fabric Close-up) %}
      <div class="aspect-square overflow-hidden bg-neutral-50 rounded-lg border border-neutral-100">
        <img 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBkyuAxMssaSMfaVQhNwBEzkRgke4CaWTnB83W3wjadzIegCAqTUYNfBLSsIFbjBI2ira2PKPalQaYt6Ddv80DQNqsSjahFjHgupMzSpe3Aj0p93YoFMywFIxC492mlsxl5pSKZ3mZXM30YStRGwpMBjdAgiiSX95DFm-iICdw-4NGLwjvL1VkhPt1HvYDIB5VXJLlmHXTClMnhriUyeNstwAJffEGk05g4gyp7TYAjWkcLAxZC1jNdTFGgw86lRE-YHSeIfVXNJl7Q" 
          alt="Fabric detailing close-up" 
          width="600"
          height="600"
          class="w-full h-full object-cover filter brightness-95 hover:brightness-100 transition-all duration-700"
        />
      </div>

      {% # 2c. Bento Detail Image 2 (Lifestyle Shot) %}
      <div class="aspect-square overflow-hidden bg-neutral-50 rounded-lg border border-neutral-100">
        <img 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuC6zKQOUOg-w2LnSK8N_W8-KsL1ZNBX4GAf3Gqvyt8bTimLgQSNI_1HVX3iBDnCGeYvFhq2vsMt4zARCO1t49Dva6x5pUfDj5iI8orMUMoDxKXVF1YP1ej5TwEsIABJZAWBfiiljj5SRKyantn7ffoVpoXJU3PIAEiURVG_XGd0z0c4c7_m5x7ISo8uh1tx8RvhEMB2SAhHD30-s27uZZUWG7kNR4idpb9hDwyt4-lUhBxtipnMllhtJlBwdCr_AQ58BIXtHoWHf97R" 
          alt="Model silhouette details" 
          width="600"
          height="600"
          class="w-full h-full object-cover filter brightness-95 hover:brightness-100 transition-all duration-700"
        />
      </div>

    </div>

    {% # Right Side: Sticky Product Information & Checkout Block %}
    <div class="lg:col-span-5 flex flex-col space-y-8 lg:sticky lg:top-28 h-fit text-left">
      
      {% # 3a. Header Details %}
      <div>
        <span class="text-[10px] font-bold text-secondary uppercase tracking-[0.25em] mb-2 block" style="font-family: 'Manrope', sans-serif;">
          The Heritage Collection
        </span>
        <h2 class="text-headline-lg md:text-[38px] font-normal text-[#5a000c] leading-tight" style="font-family: 'Noto Serif', serif; text-transform: none;">
          {% if product.title != blank %}{{ product.title }}{% else %}Lace Detail Handloom Co-ord Set{% endif %}
        </h2>
        
        {% # Interactive Pricing Row %}
        <div class="flex items-center gap-4 mt-4">
          {% if product.price != blank %}
            <span class="text-headline-md font-bold text-[#1a1b22]">{{ price | money }}</span>
            {% if is_discounted %}
              <span class="text-body-md text-neutral-400 line-through">{{ compare_at_price | money }}</span>
              <span class="bg-[#ffdad6] text-[#93000a] text-[11px] font-bold px-2 py-0.5 rounded">
                {{ discount_percent }}% OFF
              </span>
            {% endif %}
          {% else %}
            {% # High-Fidelity Mock Prices %}
            <span class="text-headline-md font-bold text-[#1a1b22]">$125.00</span>
            <span class="text-body-md text-neutral-400 line-through">$160.00</span>
            <span class="bg-[#ffdad6] text-[#93000a] text-[11px] font-bold px-2.5 py-0.5 rounded" style="font-family: 'Manrope', sans-serif;">
              22% OFF
            </span>
          {% endif %}
        </div>
      </div>

      {% # 3b. Dynamic Interactive Form %}
      {% form 'product', product, class: 'space-y-8' %}
        <input type="hidden" name="id" value="{{ current_variant.id | default: 123456789 }}" id="TatsyaaVariantId">

        {% # Color Selector Section %}
        <div class="space-y-3">
          <p class="text-[11px] font-bold uppercase tracking-wider text-secondary">
            Color: <span class="text-on-background font-bold text-neutral-800" id="TatsyaaColorLabel">Sunflower Yellow</span>
          </p>
          <div class="flex space-x-3">
            <button type="button" class="w-9 h-9 rounded-full bg-[#f4e04d] ring-2 ring-offset-2 ring-[#5a000c] transition-all cursor-pointer" onclick="selectColorOption('yellow', 'Sunflower Yellow', this)"></button>
            <button type="button" class="w-9 h-9 rounded-full bg-[#d26c8b] ring-0 ring-offset-2 ring-transparent transition-all cursor-pointer" onclick="selectColorOption('pink', 'Vintage Rose', this)"></button>
            <button type="button" class="w-9 h-9 rounded-full bg-[#f5f5dc] ring-0 ring-offset-2 ring-transparent transition-all cursor-pointer" onclick="selectColorOption('cream', 'Pristine Cream', this)"></button>
          </div>
        </div>

        {% # Size Selector Section %}
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <p class="text-[11px] font-bold uppercase tracking-wider text-secondary">Select Size</p>
            <button type="button" class="text-[#5a000c] text-[12px] underline font-bold" style="font-family: 'Manrope', sans-serif;">Size Guide</button>
          </div>
          <div class="grid grid-cols-5 gap-2" id="TatsyaaSizeGrid">
            <button type="button" class="h-11 border border-neutral-200 flex items-center justify-center font-bold text-[13px] hover:border-[#5a000c] transition-colors rounded-lg bg-white" onclick="selectSizeOption('XS', this)">XS</button>
            <button type="button" class="h-11 border border-[#5a000c] flex items-center justify-center font-bold text-[13px] bg-[#5a000c] text-white rounded-lg" onclick="selectSizeOption('S', this)">S</button>
            <button type="button" class="h-11 border border-neutral-200 flex items-center justify-center font-bold text-[13px] hover:border-[#5a000c] transition-colors rounded-lg bg-white" onclick="selectSizeOption('M', this)">M</button>
            <button type="button" class="h-11 border border-neutral-200 flex items-center justify-center font-bold text-[13px] hover:border-[#5a000c] transition-colors rounded-lg bg-white" onclick="selectSizeOption('L', this)">L</button>
            <button type="button" class="h-11 border border-neutral-200 flex items-center justify-center font-bold text-[13px] hover:border-[#5a000c] transition-colors rounded-lg bg-white" onclick="selectSizeOption('XL', this)">XL</button>
          </div>
          <input type="hidden" name="properties[Size]" value="S" id="TatsyaaSelectedSize">
        </div>

        {% # CTAs Area %}
        <div class="flex space-x-4">
          <button 
            type="submit" 
            class="flex-grow bg-[#5a000c] text-white font-bold h-14 flex items-center justify-center space-x-3 hover:bg-[#7f0f1b] transition-colors rounded-lg shadow-sm"
          >
            <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
            <span class="uppercase tracking-widest text-[12px]">Add to Cart</span>
          </button>
          <button 
            type="button" 
            class="w-14 h-14 border border-neutral-200 flex items-center justify-center hover:bg-neutral-50 transition-colors rounded-lg text-secondary hover:text-[#5a000c]"
            aria-label="Add to Wishlist"
            onclick="this.classList.toggle('text-[#5a000c]')"
          >
            <span class="material-symbols-outlined">favorite</span>
          </button>
        </div>
      {% endform %}

      {% # 3c. Detailed Editorial Description Tabs %}
      <div class="pt-8 border-t border-neutral-100">
        <div class="flex space-x-8 border-b border-neutral-100 mb-6">
          <button type="button" class="pb-2 text-[12px] font-bold uppercase tracking-wider active-tab transition-all cursor-pointer" onclick="showProductTab('details', this)">Details</button>
          <button type="button" class="pb-2 text-[12px] font-bold uppercase tracking-wider text-secondary hover:text-[#5a000c] transition-all cursor-pointer" onclick="showProductTab('care', this)">Care</button>
          <button type="button" class="pb-2 text-[12px] font-bold uppercase tracking-wider text-secondary hover:text-[#5a000c] transition-all cursor-pointer" onclick="showProductTab('shipping', this)">Shipping</button>
        </div>
        
        <div class="text-body-md text-secondary space-y-4 leading-relaxed font-light" style="font-family: 'Manrope', sans-serif;">
          
          {% # Details Tab Content %}
          <div class="tab-content-block active" id="TabProductDetails">
            {% if product.description != blank %}
              <div class="space-y-4">{{ product.description }}</div>
            {% else %}
              <p>Elevate your everyday wardrobe with our Lace Detail Co-ord Set. Handcrafted from premium breathable cotton, this two-piece ensemble features delicate circular lace inserts that celebrate traditional Indian motifs through a contemporary lens.</p>
              <ul class="list-disc pl-5 space-y-2">
                <li>100% Sustainable Artisanal Cotton</li>
                <li>Intricate Hand-cut Lace Detailing</li>
                <li>Relaxed Fit Silhouette</li>
                <li>Made in India by Master Weavers</li>
              </ul>
            {% endif %}
          </div>

          {% # Care Tab Content %}
          <div class="tab-content-block" id="TabProductCare">
            <p>Our garments are made with delicate hand-crafted details. To preserve the beauty of your heritage piece:</p>
            <ul class="list-disc pl-5 space-y-2">
              <li>Dry clean only for the first 2 washes</li>
              <li>Hand wash cold separately thereafter</li>
              <li>Do not bleach or tumble dry</li>
              <li>Steam iron on reverse side</li>
            </ul>
          </div>

          {% # Shipping Tab Content %}
          <div class="tab-content-block" id="TabProductShipping">
            <p>We craft and curate premium legacy garments with high care:</p>
            <ul class="list-disc pl-5 space-y-2">
              <li>Complimentary standard shipping across major regions</li>
              <li>International orders calculated at final checkout</li>
              <li>14-day exchange policy for unused items</li>
              <li>Estimated delivery: 5-7 business days</li>
            </ul>
          </div>

        </div>
      </div>

    </div>

  </div>

