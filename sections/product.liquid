<script>
  // 1. Color Selector and Image Swapper
  function selectColorOption(color, labelName, buttonEl) {
    // Reset borders
    const buttons = buttonEl.parentElement.querySelectorAll('button');
    buttons.forEach(b => {
      b.classList.remove('ring-2', 'ring-[#5a000c]');
      b.classList.add('ring-0', 'ring-transparent');
    });
    
    // Apply focus border
    buttonEl.classList.remove('ring-0', 'ring-transparent');
    buttonEl.classList.add('ring-2', 'ring-[#5a000c]');
    
    // Update label text
    document.getElementById('TatsyaaColorLabel').innerText = labelName;
    
    // Swap main product image based on color choice
    const mainImg = document.getElementById('TatsyaaMainImage');
    if (color === 'yellow') {
      mainImg.src = "https://lh3.googleusercontent.com/aida-public/AB6AXuAwrZkkmbCO26nbS_Elf1iGNGJbGWXAF9zK1wTVRwmKt7EwXYKQVMsLeLSTBxYjXxCpFa405EAMaPWoEVkrgpJtLq48kNdsskEcNKNQ7wLF6k2LCIE7OD7S8BzU33lqp5GmLC9CbDsEvDmoye3EwPE2rROTP5lfPqNKFNkrVkhBuKQvRmb4mzvMXc_KKWcYXZfwvrMvdJXZyVCMhXlsEdUnprl97gKhvLJtI3tWkNvuBeXa-h_r00keJJnK-jYCRpG-vdkqFHCNCt4A";
    } else if (color === 'pink') {
      mainImg.src = "https://lh3.googleusercontent.com/aida-public/AB6AXuC6zKQOUOg-w2LnSK8N_W8-KsL1ZNBX4GAf3Gqvyt8bTimLgQSNI_1HVX3iBDnCGeYvFhq2vsMt4zARCO1t49Dva6x5pUfDj5iI8orMUMoDxKXVF1YP1ej5TwEsIABJZAWBfiiljj5SRKyantn7ffoVpoXJU3PIAEiURVG_XGd0z0c4c7_m5x7ISo8uh1tx8RvhEMB2SAhHD30-s27uZZUWG7kNR4idpb9hDwyt4-lUhBxtipnMllhtJlBwdCr_AQ58BIXtHoWHf97R";
    } else if (color === 'cream') {
      mainImg.src = "https://lh3.googleusercontent.com/aida-public/AB6AXuAWYhyRl8Su-1THPrF-q6tJp-cJmiMBKMQxNYXAyjfCvHHUI5PH7cEt1NoBkFo5W8NF-kLvJJ7LscupXfzcMdKFL2z0BRfayE4BceD7mWY5s6eEhgziodmnJJmxT1DYxEELD4YvPL-sfhzUbIa6WPAmUKLUlqD1stsUAhGEKutpGElFE8-yvgWSN3K4EtsB09_60-L3B6TIKJLptS0_4sjKtYU_NkLM8d6knJXjRTya8rMfCDO8E1tnTGgYkbyyI85L6QXK-s0p3nbM";
    }
  }

  // Dual function for outer overlays
  function changeColor(color, buttonEl) {
    // Find equivalent in details form and trigger click
    const equivalentBtn = document.querySelector(`[onclick*="selectColorOption('${color}'"]`);
    if (equivalentBtn) {
      equivalentBtn.click();
    }
  }

  // 2. Size Selector Options
  function selectSizeOption(sizeValue, buttonEl) {
    const sizeButtons = document.querySelectorAll('#TatsyaaSizeGrid button');
    sizeButtons.forEach(b => {
      b.className = "h-11 border border-neutral-200 flex items-center justify-center font-bold text-[13px] hover:border-[#5a000c] transition-colors rounded-lg bg-white";
    });
    
    // Set active styles
    buttonEl.className = "h-11 border border-[#5a000c] flex items-center justify-center font-bold text-[13px] bg-[#5a000c] text-white rounded-lg";
    
    // Update hidden field
    document.getElementById('TatsyaaSelectedSize').value = sizeValue;
  }

  // 3. Tab Swapper Logic
  function showProductTab(tab, buttonEl) {
    // Update tab header focus states
    const tabButtons = buttonEl.parentElement.querySelectorAll('button');
    tabButtons.forEach(b => {
      b.classList.remove('active-tab');
      b.classList.add('text-secondary');
    });
    buttonEl.classList.add('active-tab');
    buttonEl.classList.remove('text-secondary');

    // Toggle active blocks
    document.querySelectorAll('.tab-content-block').forEach(block => {
      block.classList.remove('active');
    });
    
    if (tab === 'details') {
      document.getElementById('TabProductDetails').classList.add('active');
    } else if (tab === 'care') {
      document.getElementById('TabProductCare').classList.add('active');
    } else if (tab === 'shipping') {
      document.getElementById('TabProductShipping').classList.add('active');
    }
  }
</script>

