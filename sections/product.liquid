        <img class="w-full h-full object-cover filter brightness-95 group-hover:scale-105 group-hover:brightness-100 transition-all duration-700" width="400" height="400" alt="Instagram Style 5" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBmVs81WM8T-H1GPIT5mGASClZg4np2f7EYn94HESqcvICciFDAsNtleeN53sHx3ODT2iV2vDOvz1pwcSV2pDR4Wn0KnL8SeFUAEancQXi9fb6qnN0SPDKJYG-T3znEBwHU0vkkTxFMEATl9AD5j9dYa_z9tEMQW6542yij7fN2MLAJf4dzWz3KwNA8gciqNzUjFOwiGqGx8m42FvIB5Xd0EakkpkKmiacG1FRIL_Cx-TwF_f0QZxg-3YdWXPf-UG4r47OQCaFojIra"/>
