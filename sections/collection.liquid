    id="FilterDrawer" 
    class="fixed inset-y-0 right-0 w-[380px] max-w-[90vw] bg-white z-50 shadow-2xl p-8 border-l border-outline-variant/30 flex flex-col justify-between translate-x-full transition-transform duration-300 ease-out"
  >
    <div class="overflow-y-auto max-h-[85vh] pr-2 custom-scrollbar">
      <div class="flex justify-between items-center mb-8 border-b border-outline-variant/20 pb-4">
        <h2 class="text-headline-md font-headline-md text-primary">Filters</h2>
        <button 
          type="button" 
          id="FilterDrawerCloseBtn" 
          class="text-secondary hover:text-primary transition-colors flex items-center justify-center"
          aria-label="Close filters"
        >
          <span class="material-symbols-outlined text-[24px]">close</span>
        </button>
      </div>

      {% # Render shared filters for mobile drawer %}
      {% render 'collection-filters-ui', id_prefix: 'mobile' %}
    </div>

    {% # Mobile Drawer Actions %}
    <div class="border-t border-outline-variant/20 pt-6 flex gap-4 bg-white">
      <button 
        type="button" 
        class="ResetFiltersBtn flex-grow border border-outline/20 py-3 text-label-md font-label-md text-secondary uppercase tracking-widest hover:border-primary hover:text-primary transition-all text-[12px]"
      >
        Reset All
      </button>
      <button 
        type="button" 
        id="ApplyFiltersBtn" 
        class="flex-grow bg-primary-container text-white py-3 text-label-md font-label-md uppercase tracking-widest hover:bg-primary transition-all shadow-sm text-[12px]"
