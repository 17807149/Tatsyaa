{% # CSS Classes for Filter Styling %}
<style>
  /* Custom filter checkbox styling */
  .filter-checkbox {
    accent-color: var(--color-primary, #5a000c);
  }
  .size-chip-btn {
    transition: all 0.2s ease;
  }
  .size-chip-btn.active-chip {
    background-color: var(--color-primary, #5a000c) !important;
    color: #ffffff !important;
    border-color: var(--color-primary, #5a000c) !important;
  }
</style>

{% # 5. Interactive Clientside Javascript for Synchronized Filters & Sorting %}
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Basic elements
    const filterBtn = document.getElementById('FilterDrawerToggleBtn');
    const closeBtn = document.getElementById('FilterDrawerCloseBtn');
    const drawer = document.getElementById('FilterDrawer');
    const backdrop = document.getElementById('DrawerBackdrop');
    const sortSelect = document.getElementById('SortSelect');
    const grid = document.getElementById('TatsyaaProductGrid');
    const cards = Array.from(grid.querySelectorAll('.product-card'));
    const countDisplay = document.getElementById('ProductCount');

    // Drawer Open/Close Toggles
    const openDrawer = () => {
      drawer.classList.remove('translate-x-full');
      backdrop.classList.remove('hidden');
      setTimeout(() => backdrop.classList.add('opacity-100'), 10);
    };

    const closeDrawer = () => {
      drawer.classList.add('translate-x-full');
      backdrop.classList.remove('opacity-100');
      setTimeout(() => backdrop.classList.add('hidden'), 300);
    };

    if (filterBtn) filterBtn.addEventListener('click', openDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (backdrop) backdrop.addEventListener('click', closeDrawer);

    // Dynamic Filter State
    let filterState = {
      availability: [],
      style: [],
      age: [],
      size: '',
      price: 300
    };

    // Shared UI elements between Desktop sidebar and Mobile drawer
    const syncUIAndState = (sourcePrefix, targetPrefix) => {
      // 1. Availability sync
      const sourceAvail = Array.from(document.querySelectorAll(`.${sourcePrefix}-avail-input:checked`)).map(el => el.value);
      document.querySelectorAll(`.${targetPrefix}-avail-input`).forEach(el => {
        el.checked = sourceAvail.includes(el.value);
      });
      filterState.availability = sourceAvail;

      // 2. Style sync
      const sourceStyle = Array.from(document.querySelectorAll(`.${sourcePrefix}-style-input:checked`)).map(el => el.value);
      document.querySelectorAll(`.${targetPrefix}-style-input`).forEach(el => {
        el.checked = sourceStyle.includes(el.value);
      });
      filterState.style = sourceStyle;

      // 3. Age sync
      const sourceAge = Array.from(document.querySelectorAll(`.${sourcePrefix}-age-input:checked`)).map(el => el.value);
      document.querySelectorAll(`.${targetPrefix}-age-input`).forEach(el => {
        el.checked = sourceAge.includes(el.value);
      });
      filterState.age = sourceAge;

      // 4. Size sync
      const sourceActiveSizeBtn = document.querySelector(`.${sourcePrefix}-size-btn.active-chip`);
      const selectedSize = sourceActiveSizeBtn ? sourceActiveSizeBtn.getAttribute('data-size') : '';
      document.querySelectorAll(`.${targetPrefix}-size-btn`).forEach(el => {
        if (el.getAttribute('data-size') === selectedSize) {
          el.classList.add('active-chip');
        } else {
          el.classList.remove('active-chip');
        }
      });
      filterState.size = selectedSize;

      // 5. Price sync
      const sourcePriceVal = document.getElementById(`${sourcePrefix}-PriceRangeInput`).value;
      document.getElementById(`${targetPrefix}-PriceRangeInput`).value = sourcePriceVal;
      document.getElementById(`${targetPrefix}-PriceDisplay`).textContent = '$' + sourcePriceVal;
      document.getElementById(`${sourcePrefix}-PriceDisplay`).textContent = '$' + sourcePriceVal;
      filterState.price = parseInt(sourcePriceVal);
    };

    // Apply Filter Logic
    const applyFilters = () => {
      grid.style.opacity = '0.5';
      setTimeout(() => {
        let visibleCount = 0;
        
        cards.forEach(card => {
          const price = parseFloat(card.getAttribute('data-price')) || 0;
          const category = card.getAttribute('data-category') || 'All';
          const fabric = card.getAttribute('data-fabric') || 'All';
          const availability = card.getAttribute('data-availability') || '';
          const sizeStr = card.getAttribute('data-size') || '';
          const age = card.getAttribute('data-age') || 'Adults';

          // Availability Filter
          const matchesAvail = filterState.availability.length === 0 || filterState.availability.includes(availability);
          
          // Style Filter
          const matchesStyle = filterState.style.length === 0 || filterState.style.includes(category);
          
          // Age Filter
          const matchesAge = filterState.age.length === 0 || filterState.age.includes(age);
          
          // Size Filter
          const cardSizes = sizeStr.split(',').map(s => s.trim().toUpperCase());
          const matchesSize = filterState.size === '' || cardSizes.includes(filterState.size.toUpperCase());
          
          // Price Filter
          const matchesPrice = price <= filterState.price;

          // Combined check
          if (matchesAvail && matchesStyle && matchesAge && matchesSize && matchesPrice) {
            card.style.display = 'block';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        countDisplay.textContent = visibleCount + (visibleCount === 1 ? ' Product' : ' Products');
        grid.style.opacity = '1';
      }, 200);
    };

    // Listeners for Desktop inputs
    document.querySelectorAll('[class^="desktop-"]').forEach(input => {
      input.addEventListener('change', () => {
        syncUIAndState('desktop', 'mobile');
        applyFilters();
      });
    });

    // Handle Size chip clicks in Desktop
    document.querySelectorAll('.desktop-size-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const wasActive = btn.classList.contains('active-chip');
        document.querySelectorAll('.desktop-size-btn').forEach(b => b.classList.remove('active-chip'));
        if (!wasActive) btn.classList.add('active-chip');
        
        syncUIAndState('desktop', 'mobile');
        applyFilters();
      });
    });

    // Price input real-time value changes in Desktop
    const desktopPriceInput = document.getElementById('desktop-PriceRangeInput');
    desktopPriceInput.addEventListener('input', () => {
      syncUIAndState('desktop', 'mobile');
      applyFilters();
    });

    // Price input real-time value changes in Mobile
    const mobilePriceInput = document.getElementById('mobile-PriceRangeInput');
    mobilePriceInput.addEventListener('input', () => {
      syncUIAndState('mobile', 'desktop');
    });

    // Handle Size chip clicks in Mobile
    document.querySelectorAll('.mobile-size-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const wasActive = btn.classList.contains('active-chip');
        document.querySelectorAll('.mobile-size-btn').forEach(b => b.classList.remove('active-chip'));
        if (!wasActive) btn.classList.add('active-chip');
        
        syncUIAndState('mobile', 'desktop');
      });
    });

    // Mobile Drawer Apply Trigger
    const mobileApplyBtn = document.getElementById('ApplyFiltersBtn');
    if (mobileApplyBtn) {
      mobileApplyBtn.addEventListener('click', () => {
        syncUIAndState('mobile', 'desktop');
        applyFilters();
        closeDrawer();
      });
    }

    // Reset Buttons Trigger
    document.querySelectorAll('.ResetFiltersBtn').forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset check boxes
        document.querySelectorAll('input[type="checkbox"]').forEach(c => c.checked = false);
        // Reset sizes
        document.querySelectorAll('.size-chip-btn').forEach(b => b.classList.remove('active-chip'));
        // Reset sliders
        document.querySelectorAll('input[type="range"]').forEach(r => {
          r.value = 300;
        });
        document.querySelectorAll('[id$="-PriceDisplay"]').forEach(d => d.textContent = '$300');
        
        filterState = {
          availability: [],
          style: [],
          age: [],
          size: '',
          price: 300
        };

        applyFilters();
        closeDrawer();
      });
    });

    // Sorting Logic
    if (sortSelect) {
      sortSelect.addEventListener('change', () => {
        const criteria = sortSelect.value;
        const sortedCards = [...cards];

        sortedCards.sort((a, b) => {
          const priceA = parseFloat(a.getAttribute('data-price')) || 0;
          const priceB = parseFloat(b.getAttribute('data-price')) || 0;
          const titleA = a.getAttribute('data-title').toLowerCase();
          const titleB = b.getAttribute('data-title').toLowerCase();

          if (criteria === 'price-low') {
            return priceA - priceB;
          } else if (criteria === 'price-high') {
            return priceB - priceA;
          } else if (criteria === 'title-az') {
            return titleA.localeCompare(titleB);
          } else {
            return cards.indexOf(a) - cards.indexOf(b); // Default featured order
          }
        });

        grid.style.opacity = '0.5';
        setTimeout(() => {
          grid.innerHTML = '';
          sortedCards.forEach(card => grid.appendChild(card));
          grid.style.opacity = '1';
        }, 200);
      });
    }

    // Initial count display
    countDisplay.textContent = cards.length + ' Products';
  });
</script>

