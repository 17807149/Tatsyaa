{% comment %}
  Tatsyaa High-Fidelity Shop All / Collection Section
  -------------------------------------------------------------
  Description: Displays a grid of products with a desktop left sidebar and mobile drawer.
  Includes:
    - Pure white page background.
    - Dynamic breadcrumbs (Home / Collections / Title).
    - Filters: Style, Age Group, Size, Price Range, Availability.
    - Responsive 3-column grid on desktop, 2-column on mobile.
    - Synchronized clientside multi-filtering and sorting.
{% endcomment %}

<section class="w-full bg-white py-12 px-margin-desktop max-w-container-max mx-auto full-width" id="TatsyaaCollectionSection">
  
  {% # 1. Dynamic Breadcrumbs %}
  <nav class="text-label-md text-secondary/70 uppercase tracking-[0.15em] mb-8 flex gap-2 items-center text-[12px]" aria-label="breadcrumbs">
    <a href="{{ routes.root_url }}" class="hover:text-primary transition-colors">Home</a>
    <span class="text-outline-variant">/</span>
    {% if collection.handle %}
      <a href="/collections" class="hover:text-primary transition-colors">Collections</a>
      <span class="text-outline-variant">/</span>
      <span class="text-primary font-semibold">{{ collection.title }}</span>
    {% else %}
      <span class="text-primary font-semibold">Shop All</span>
    {% endif %}
  </nav>

  {% # 2. Editorial Header %}
  <header class="text-left mb-12 border-b border-outline-variant/20 pb-8" data-aos="fade-up">
    <h1 class="text-display-lg font-display-lg text-primary mb-3">
      {{ collection.title | default: "Shop All" }}
    </h1>
    <p class="text-body-lg text-secondary max-w-4xl leading-relaxed">
      {{ collection.description | default: "Explore our foundational edits blending centuries of artisanal homegrown legacy with modern, architectural silhouettes." }}
    </p>
  </header>

  {% # 3. Main Filter & Grid Layout Split %}
  <div class="flex flex-col md:flex-row gap-12 items-start">
    
    {% # DESKTOP LEFT SIDEBAR FILTERS (Visible md+, hidden mobile) %}
    <aside class="hidden md:block w-72 shrink-0 border-r border-outline-variant/30 pr-8 sticky top-24">
      <div class="flex justify-between items-center mb-8 border-b border-outline-variant/20 pb-4">
        <h2 class="text-headline-md font-headline-md text-primary">Filters</h2>
        <button type="button" class="ResetFiltersBtn text-label-md text-secondary hover:text-primary uppercase tracking-widest text-[11px] font-semibold">Clear All</button>
      </div>

      {% # Render all filter subsections %}
      {% render 'collection-filters-ui', id_prefix: 'desktop' %}
    </aside>

    {% # RIGHT MAIN CONTENT (Toolbar + Product Grid) %}
    <div class="flex-grow w-full">
      
      {% # Filter & Sort Toolbar %}
      <div class="border-b border-outline-variant/20 pb-6 mb-10 flex flex-col sm:flex-row justify-between items-center gap-6">
        <div class="text-label-md font-label-md text-on-surface-variant uppercase tracking-widest flex items-center gap-2 text-[12px]">
          <span class="material-symbols-outlined text-[16px] text-outline">widgets</span>
          <span id="ProductCount">10 Products</span>
        </div>
        
        <div class="flex gap-4 items-center w-full sm:w-auto justify-between sm:justify-end">
          {% # Mobile Drawer Trigger (Hidden on md+) %}
          <button 
            type="button" 
            id="FilterDrawerToggleBtn"
            class="md:hidden flex items-center gap-2 text-label-md font-label-md text-primary uppercase tracking-widest border border-outline/20 px-5 py-3 hover:bg-primary hover:text-white transition-all text-[12px]"
          >
            <span class="material-symbols-outlined text-[18px]">filter_list</span>
            Filters
          </button>

          {% # Sort Dropdown %}
          <div class="relative min-w-[220px]">
            <select 
              id="SortSelect" 
              aria-label="Sort products"
              class="w-full bg-white border border-outline/20 px-4 py-3 text-label-md font-label-md text-secondary outline-none focus:border-primary uppercase tracking-wider appearance-none rounded-none cursor-pointer text-[12px]"
            >
              <option value="featured">Featured</option>
              <option value="price-low">Price: Low to High</option>
              <option value="price-high">Price: High to Low</option>
              <option value="title-az">Name: A to Z</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none select-none">arrow_drop_down</span>
          </div>
        </div>
      </div>

      {% # Product Grid (3 columns md+, 2 columns mobile) %}
      <div 
        id="TatsyaaProductGrid" 
        class="grid grid-cols-2 lg:grid-cols-3 gap-x-gutter gap-y-12 transition-opacity duration-300 min-h-[400px]"
      >
        {% assign chosen_products = collection.products %}
        {% if chosen_products.size > 0 %}
          
          {% # Live Products loop %}
          {% for product in chosen_products %}
            <div 
              class="group product-card" 
              data-price="{{ product.price }}"
              data-title="{{ product.title | escape }}"
              data-category="{{ product.type | default: 'All' }}"
              data-fabric="Cotton"
              data-size="S, M, L"
              data-age="Adults"
              data-availability="In Stock"
            >
              <div class="relative aspect-[3/4] overflow-hidden bg-surface-container mb-4">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105', loading: 'lazy' }}
                {% endif %}
                <div class="absolute inset-0 bg-black/5 group-hover:bg-black/15 transition-all"></div>
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col gap-2 w-[85%] opacity-0 group-hover:opacity-100 transition-all duration-300">
                  <a href="{{ product.url }}" class="bg-white/95 text-primary text-center py-3 text-label-md font-label-md uppercase tracking-wider shadow-lg hover:bg-primary-container hover:text-white transition-all text-[12px]">Quick View</a>
                </div>
              </div>
              <div class="text-center px-2">
                <h3 class="font-headline-md text-headline-sm text-primary mb-1 truncate px-1">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                <p class="text-body-md font-body-md text-outline">{{ product.price | money }}</p>
              </div>
            </div>
          {% endfor %}
          
