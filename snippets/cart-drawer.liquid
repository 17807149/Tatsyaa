{% comment %}
  Tatsyaa Luxury Editorial Cart Drawer Snippet
  -------------------------------------------------------------
  Description: A high-fidelity sliding cart drawer matching Sabyasachi / Stitch design aesthetics.
  Features:
    - Slide-out transition from the right side of the screen.
    - Soft shape styling with extremely diffused low-opacity burgundy ambient shadow.
    - Fully dynamic Shopify cart item loop with premium mock items fallback for development.
    - Floating action button on the right-hand side with a badge.
    - Interactive quantity selectors, subtotal calculation, and secure checkout CTA.
{% endcomment %}

<style>
  #TatsyaaCartDrawer {
    box-shadow: -10px 0 40px rgba(90, 0, 12, 0.04);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #TatsyaaCartBackdrop {
    transition: opacity 0.3s ease;
  }
</style>

{% # 1. Floating Bag Action Button on Right-Hand Side %}
<button 
  type="button" 
  id="TatsyaaFloatingCartBtn" 
  class="fixed right-6 bottom-22 z-40 bg-[#5a000c] text-white w-12 h-12 rounded-full shadow-xl hover:bg-[#7f0f1b] transition-all flex items-center justify-center hover:scale-105 duration-300"
  aria-label="Open Cart Bag Drawer"
>
  <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
  <span class="absolute -top-1 -right-1 bg-[#ffdad8] text-[#5a000c] text-[9.5px] w-5 h-5 flex items-center justify-center rounded-full font-bold shadow-sm" id="FloatingCartCount">
    {% if cart.item_count > 0 %}{{ cart.item_count }}{% else %}2{% endif %}
  </span>
</button>

{% # 2. Darkened Blur Backdrop Overlay %}
<div 
  id="TatsyaaCartBackdrop" 
  class="fixed inset-0 bg-black/25 backdrop-blur-[2px] z-50 opacity-0 pointer-events-none transition-opacity"
  aria-hidden="true"
></div>

{% # 3. Slide-out Cart Drawer Box %}
<div 
  id="TatsyaaCartDrawer" 
  class="fixed right-0 top-0 bottom-0 h-full w-full max-w-[420px] bg-white border-l border-neutral-100 z-50 transform translate-x-full flex flex-col rounded-l-xl text-left"
>
  
  {% # Header Section %}
  <div class="px-6 py-6 border-b border-neutral-100 flex justify-between items-center bg-[#fbf8ff]">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-[#5a000c] text-[22px]">shopping_bag</span>
      <h2 class="text-[18px] font-medium text-[#5a000c]" style="font-family: 'Noto Serif', serif;">
        Shopping Bag
      </h2>
      <span class="text-[11px] font-bold bg-[#ffdad8] text-[#5a000c] px-2 py-0.5 rounded-full" id="CartHeaderCount">
        {% if cart.item_count > 0 %}{{ cart.item_count }}{% else %}2{% endif %}
      </span>
    </div>
    <button 
      type="button" 
      id="TatsyaaCartCloseBtn" 
      class="text-secondary hover:text-[#5a000c] transition-colors p-1.5 flex items-center justify-center hover:bg-neutral-50 rounded"
      aria-label="Close Shopping Bag"
    >
      <span class="material-symbols-outlined text-[24px]">close</span>
    </button>
  </div>

  {% # Scrollable Content Items Area %}
  <div class="flex-grow overflow-y-auto px-6 py-4 space-y-6" id="CartItemsContainer">
    
    {% if cart.item_count > 0 %}
      {% # Render Active Shopify Cart Items %}
      {% for item in cart.items %}
        <div class="flex gap-4 border-b border-neutral-50 pb-6 items-start" data-variant-id="{{ item.variant_id }}">
          <div class="w-20 h-24 bg-neutral-50 overflow-hidden rounded border border-neutral-100 flex-shrink-0">
            {% if item.image != blank %}
              <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" width="80" height="106" class="w-full h-full object-cover">
            {% endif %}
          </div>
          <div class="flex-grow space-y-1">
            <h3 class="font-bold text-[14px] text-neutral-800 leading-tight" style="font-family: 'Manrope', sans-serif;">{{ item.product.title }}</h3>
            {% unless item.product.has_only_default_variant %}
              <p class="text-[11px] text-neutral-400 font-semibold tracking-wider uppercase">{{ item.variant.title }}</p>
            {% endunless %}
            <div class="flex justify-between items-center pt-2">
              {% # Quantity Selector %}
              <div class="flex items-center border border-neutral-200 rounded">
                <button type="button" class="px-2 py-1 text-secondary hover:text-[#5a000c]" onclick="changeCartQty('{{ item.variant_id }}', -1)">-</button>
                <span class="px-2.5 py-1 text-[13px] font-bold text-neutral-800">{{ item.quantity }}</span>
                <button type="button" class="px-2 py-1 text-secondary hover:text-[#5a000c]" onclick="changeCartQty('{{ item.variant_id }}', 1)">+</button>
              </div>
              <span class="text-[14px] font-bold text-neutral-800" style="font-family: 'Manrope', sans-serif;">{{ item.final_line_price | money }}</span>
            </div>
          </div>
        </div>
      {% endfor %}
    {% else %}
      {% # High-Fidelity Mock Items for Blank Catalog Previews %}
      <!-- Mock Item 1: Anya Lace Tunic Set -->
      <div class="flex gap-4 border-b border-neutral-100 pb-6 items-start" id="MockCartItem1">
        <div class="w-20 h-26 bg-neutral-50 overflow-hidden rounded-lg border border-neutral-100 flex-shrink-0">
          <img 
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuABPwn0l3VFDG4m3Qb9NgoNgDR56XFHtwwlo4KDdf0w0czfdFb8uH0t4ned1hqJI4_FkQmbobfi0UHKePVDAVELdnb9A62wssN5Isqoy3-BD2hBij-5at35iFiIdYp5NNCdcmt0ZlqCfsR_zgFYS72jLP69MEbJfwH48EHwIjMx4q-2M67JkpqYf0-DSqs83lN1kovpJSfRK25BPcUTS5YNs6uQdxDSERrvSLXGKn95hv0A6ScLAPT-P733lZWlE4ayAGXhaO8M7UoV" 
            alt="Anya Lace Tunic Set" 
            width="80" 
            height="106" 
            class="w-full h-full object-cover"
          >
        </div>
        <div class="flex-grow space-y-1 text-left">
          <h3 class="font-bold text-[14.5px] text-neutral-800 leading-tight" style="font-family: 'Manrope', sans-serif;">Anya Lace Tunic Set</h3>
          <p class="text-[10px] text-neutral-400 font-bold tracking-wider uppercase" style="font-family: 'Manrope', sans-serif;">Sunflower Yellow / S</p>
          <div class="flex justify-between items-center pt-3">
            <div class="flex items-center border border-neutral-200 rounded-lg">
              <button type="button" class="px-2.5 py-1 text-secondary hover:text-[#5a000c] text-[15px]" onclick="updateMockQty(1, -1)">-</button>
              <span class="px-2.5 py-1 text-[13px] font-bold text-neutral-800" id="MockQty1">1</span>
              <button type="button" class="px-2.5 py-1 text-secondary hover:text-[#5a000c] text-[15px]" onclick="updateMockQty(1, 1)">+</button>
            </div>
            <span class="text-[14.5px] font-bold text-neutral-800" style="font-family: 'Manrope', sans-serif;">$125.00</span>
          </div>
        </div>
      </div>

      <!-- Mock Item 2: Meera Silk Waistcoat -->
      <div class="flex gap-4 border-b border-neutral-100 pb-6 items-start" id="MockCartItem2">
        <div class="w-20 h-26 bg-neutral-50 overflow-hidden rounded-lg border border-neutral-100 flex-shrink-0">
          <img 
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDfcKJMO4Ndp7BDje8i1plFA5yaxrizYF1gghwLktFbjnNIUJ24Tpfaaj4YvVn3WrTbv-8wHFtEyRI5aeGohaOqcAGuqRxemr1Hee21I5E7tyhJ2SOVKHPeAIlAqs8an41ZKQqFuPRJzlXU7Km4LowVFoUyQIY1FwJVvBQ4rvjgYF7sTlSXj5tlUqwW37i9ASV2NkqO80EnV9M3kjW_lCdsof9L6EMWlNgOOruU-nxjlGO9VxjRv-3yPKWhMrXbgxJJZ86OC51JvsjQ" 
            alt="Meera Silk Waistcoat" 
            width="80" 
            height="106" 
            class="w-full h-full object-cover"
          >
        </div>
        <div class="flex-grow space-y-1 text-left">
          <h3 class="font-bold text-[14.5px] text-neutral-800 leading-tight" style="font-family: 'Manrope', sans-serif;">Meera Silk Waistcoat</h3>
          <p class="text-[10px] text-neutral-400 font-bold tracking-wider uppercase" style="font-family: 'Manrope', sans-serif;">Vintage Rose / M</p>
          <div class="flex justify-between items-center pt-3">
            <div class="flex items-center border border-neutral-200 rounded-lg">
              <button type="button" class="px-2.5 py-1 text-secondary hover:text-[#5a000c] text-[15px]" onclick="updateMockQty(2, -1)">-</button>
              <span class="px-2.5 py-1 text-[13px] font-bold text-neutral-800" id="MockQty2">1</span>
              <button type="button" class="px-2.5 py-1 text-secondary hover:text-[#5a000c] text-[15px]" onclick="updateMockQty(2, 1)">+</button>
            </div>
            <span class="text-[14.5px] font-bold text-neutral-800" style="font-family: 'Manrope', sans-serif;">$85.00</span>
          </div>
        </div>
      </div>
    {% endif %}

  </div>

  {% # Dedicated Footer Sticky Subtotal & Checkout Area %}
  <div class="px-6 py-6 border-t border-neutral-100 bg-[#fbf8ff] rounded-bl-xl space-y-4">
    <div class="flex justify-between items-center">
      <span class="text-neutral-500 font-bold uppercase tracking-wider text-[11px]" style="font-family: 'Manrope', sans-serif;">Subtotal</span>
      <span class="text-[18px] font-bold text-neutral-800" style="font-family: 'Manrope', sans-serif;" id="CartSubtotalDisplay">
        {% if cart.item_count > 0 %}{{ cart.total_price | money }}{% else %}$210.00{% endif %}
      </span>
    </div>
    <div class="space-y-2">
      <a 
        href="/checkout" 
        class="w-full bg-[#5a000c] text-white py-4 px-10 text-[12px] font-bold uppercase tracking-widest hover:bg-[#7f0f1b] transition-all rounded-lg flex items-center justify-center gap-2 shadow-sm"
        style="font-family: 'Manrope', sans-serif;"
      >
        <span>Secure Checkout</span>
        <span class="material-symbols-outlined text-[18px]">lock</span>
      </a>
      <p class="text-[11px] text-neutral-400 font-medium leading-relaxed text-center" style="font-family: 'Manrope', sans-serif;">
        Shipping & taxes calculated at checkout.<br>Handcrafted with love in India.
      </p>
    </div>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const floatingBtn = document.getElementById('TatsyaaFloatingCartBtn');
    const closeBtn = document.getElementById('TatsyaaCartCloseBtn');
    const drawer = document.getElementById('TatsyaaCartDrawer');
    const backdrop = document.getElementById('TatsyaaCartBackdrop');
    
    // Bind main navigation menu shopping bag icon as well
    const menuCartBtns = document.querySelectorAll('a[href="/cart"], [aria-label="Shopping Bag"]');
    
    const openCartDrawer = (e) => {
      if (e) e.preventDefault();
      drawer.classList.remove('translate-x-full');
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      backdrop.classList.add('opacity-100');
    };
    
    const closeCartDrawer = () => {
      drawer.classList.add('translate-x-full');
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
    };
    
    if (floatingBtn) floatingBtn.addEventListener('click', openCartDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeCartDrawer);
    if (backdrop) backdrop.addEventListener('click', closeCartDrawer);
    
    menuCartBtns.forEach(btn => {
      btn.addEventListener('click', openCartDrawer);
    });
  });

  // Mock Cart Quantity Updates
  let mockPrices = { 1: 125.00, 2: 85.00 };
  let mockQtys = { 1: 1, 2: 1 };

  function updateMockQty(itemId, change) {
    const qtyEl = document.getElementById(`MockQty${itemId}`);
    let newQty = mockQtys[itemId] + change;
    
    if (newQty < 0) return;
    
    mockQtys[itemId] = newQty;
    qtyEl.innerText = newQty;
    
    // Hide item from layout if qty is 0
    if (newQty === 0) {
      document.getElementById(`MockCartItem${itemId}`).style.display = 'none';
    }
    
    // Calculate new subtotal and count
    recalculateMockCart();
  }

  function recalculateMockCart() {
    let total = 0;
    let itemCount = 0;
    
    for (let key in mockQtys) {
      total += mockQtys[key] * mockPrices[key];
      itemCount += mockQtys[key];
    }
    
    // Update displays
    document.getElementById('CartSubtotalDisplay').innerText = `$${total.toFixed(2)}`;
    document.getElementById('CartHeaderCount').innerText = itemCount;
    document.getElementById('FloatingCartCount').innerText = itemCount;
    
    const navBagBadge = document.querySelector('a[href="/cart"] span.absolute');
    if (navBagBadge) {
      navBagBadge.innerText = itemCount;
    }
  }
</script>
