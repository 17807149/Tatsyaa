{% comment %}
  Tatsyaa Luxury Editorial About Us / Our Story Page Snippet
  -------------------------------------------------------------
  Description: A high-fidelity, premium brand history page styled according to the modern heritage aesthetic.
{% endcomment %}

<style>
  .heritage-grain {
    background-image: radial-gradient(#dfbfbd 0.5px, transparent 0.5px);
    background-size: 24px 24px;
    opacity: 0.15;
  }
  .editorial-image-reveal {
    clip-path: inset(100% 0 0 0);
    transition: clip-path 1.2s cubic-bezier(0.77, 0, 0.175, 1);
  }
  .editorial-image-reveal.active {
    clip-path: inset(0 0 0 0);
  }
</style>

<section class="w-full bg-white relative overflow-hidden full-width" id="TatsyaaAboutSection">
  
  {% # 1. Cinematic Parallax Hero Header %}
  <header class="relative h-[650px] md:h-[750px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuAmwRYfKX0j2LYIN-S5EzkoLKJqJGhqqYU9z-vBkWSfB5hcOIMrhxG0tjuLuVDpHTHhRTey9WRlNW-zC7GEkq-4wpNZXorq6QKGmYaGH7N-d6hPahG2MRB90AsUVzswhZ7kNmnvGSow2Hio8d6AlDujf4zYQJDxyTldmLNDUeltkl9jWx0RSw9PSmMAk4l888JU_hHgFLVa3sjtf5kGxXnJMNLAQyry6kBKYpxxb270YenYuGdzGuvG7FCfzlqy_xyjW00sZZXqBz0_" 
        alt="Artisanal Hand-woven Indian Fabric Editorial draping" 
        width="1600"
        height="900"
        class="w-full h-full object-cover opacity-90 scale-105 filter brightness-[0.85]"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-white"></div>
    </div>
    
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <h1 class="text-headline-lg md:text-[56px] font-normal text-white mb-6 drop-shadow-sm leading-tight" style="font-family: 'Noto Serif', serif; text-transform: none;">
        Crafting Contemporary Legacies
      </h1>
      <p class="text-body-md md:text-body-lg text-white max-w-2xl mx-auto uppercase tracking-[0.25em] opacity-95 font-bold" style="font-family: 'Manrope', sans-serif;">
        Where ancestral looms meet the modern silhouette.
      </p>
    </div>
  </header>

  {% # 2. Narrative Focus: Our Heritage ("The Genesis") %}
  <section class="py-24 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-center">
      
      {% # Left narrative text %}
      <div class="lg:col-span-5 space-y-6 text-left">
        <span class="text-[10px] font-bold text-[#5a000c] tracking-[0.25em] uppercase block" style="font-family: 'Manrope', sans-serif;">
          The Genesis
        </span>
        <h2 class="text-headline-lg md:text-[38px] font-normal text-[#5a000c] leading-tight" style="font-family: 'Noto Serif', serif; text-transform: none;">
          A Commitment to the Homegrown
        </h2>
        <p class="text-body-md text-secondary leading-relaxed font-light" style="font-family: 'Manrope', sans-serif;">
          Tatsyaa was born from a singular vision: to bridge the gap between India's vast, centuries-old artisanal landscape and the discerning modern global wardrobe. We believe that true luxury isn't just found in a label, but in the rhythm of a handloom, the precision of a master embroiderer, and the patience of a vegetable dyer.
        </p>
        <p class="text-body-md text-secondary leading-relaxed font-light" style="font-family: 'Manrope', sans-serif;">
          Every piece curated at Tatsyaa tells a story of a specific region, a distinct community, and a craft that has survived through generations. By partnering directly with homegrown designers, we ensure that the soul of Indian heritage is preserved while being reimagined for today's lifestyle.
        </p>
      </div>

      {% # Right picture frame %}
      <div class="lg:col-start-7 lg:col-span-6 relative mt-12 lg:mt-0">
        <div class="aspect-[4/5] overflow-hidden rounded-lg shadow-md border border-neutral-100 relative z-10">
          <img 
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDxwU9SwtMkU5tt6M-pcQC2A5yufPLnaXD82Um9EufL-AAN7sjpinw8_bR1_ElOR3N2Usv-hOFU0ngqrU-WdSIZR19PdlekXKJzmuGhYNp6tlU521UUks0POBk7Do0jegrbc9Oe4Se96bLSU2HmyFi7E7w0MSOEFLvIM2pLulqB6cRYc7gtBYB_0iyUD6DbvVbp9adkC_xZTGrpeKg7AlTNLW5ZW3nzrLIVfzt_J2Qmh6VvpS-YRkA-GQWkE2IAIXyDYgzgiayNdwwt" 
            alt="Intricate embroidery frame demonstrating Zardozi hand craft details" 
            width="800"
            height="1000"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000"
          />
        </div>
        {% # Decorative frame background element %}
        <div class="absolute -bottom-6 -left-6 w-44 h-44 border border-[#5a000c]/15 -z-0 hidden lg:block rounded-lg"></div>
      </div>

    </div>
  </section>

  {% # 3. The Makers: Behind the Scenes ("The Custodians of Craft") %}
  <section class="bg-[#fbf8ff] py-28 relative border-y border-neutral-100">
    <div class="absolute inset-0 heritage-grain -z-0"></div>
    
    <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto relative z-10">
      
      <div class="text-center max-w-2xl mx-auto mb-20">
        <h2 class="text-headline-lg md:text-[36px] font-normal text-[#5a000c] mb-3" style="font-family: 'Noto Serif', serif; text-transform: none;">
          The Custodians of Craft
        </h2>
        <p class="text-[10px] font-bold text-secondary tracking-[0.25em] uppercase" style="font-family: 'Manrope', sans-serif;">
          Honoring the Hands Behind the Fabric
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        {% # Maker card 1 %}
        <div class="group text-left space-y-4">
          <div class="aspect-square overflow-hidden rounded-lg border border-neutral-100 bg-white">
            <img 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCguwVg4wSmTk5DFeqOnB7e_VzfmqEMdBgUz-ePfhByOP-0CiAT3fvrSlaDicVQJvv6qtQEql-CeVJEObmIaiuWZq_D84kkUyF8LQlU9J2R2Vz12m0B5wFpz0x9-2Ct7-ybyeQtkVuYVDQK-ReDPq31-8L9fUBf3jO0b2ShxDpanK1XKtiV3JmckDubHVXhlTk951xZHmffkRqUPBQenp1wMc25dcfv6OeEah4xE3cDgJT5tX31zu8sF7qqBY_eaxBgkNvJUErHwYm5" 
              alt="Artisanal weaver sitting at a traditional handloom" 
              width="600"
              height="600"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 filter brightness-95 group-hover:brightness-100"
            />
          </div>
          <div>
            <h3 class="text-headline-md font-medium text-[#5a000c]" style="font-family: 'Noto Serif', serif; text-transform: none;">Master Weavers</h3>
            <p class="text-[10px] font-bold text-secondary tracking-widest uppercase mt-1" style="font-family: 'Manrope', sans-serif;">BANARAS & KANCHIPURAM</p>
          </div>
        </div>

        {% # Maker card 2 %}
        <div class="group text-left space-y-4 md:translate-y-8">
          <div class="aspect-square overflow-hidden rounded-lg border border-neutral-100 bg-white">
            <img 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAvLRlGrM-AKmXD3d4na--EsrAwj6lETcMG3n-vms4iCb_J5GOHEG4BmZVRBESCsyimY2LTj5GoQqTGTvKKqsgHikxT5Ox8ZLFSepaaw2ACjfstTgP68HGY-zpM5nuBuCCoOiY_5whFgDfY6koJH_Lj0gEBrsf6xq-PAHDPHb1A0RcgwkKbz6l_GcyiXjnsdt1slt4BNBSppt2RsYv1gipD5bRNor0nrj6YCMs22EIPyOAHv1fBGEUXzg6UzvpHuVHOBkB46YaTHVCM" 
              alt="Indigo pigment block printing process close up" 
              width="600"
              height="600"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 filter brightness-95 group-hover:brightness-100"
            />
          </div>
          <div>
            <h3 class="text-headline-md font-medium text-[#5a000c]" style="font-family: 'Noto Serif', serif; text-transform: none;">Block Printers</h3>
            <p class="text-[10px] font-bold text-secondary tracking-widest uppercase mt-1" style="font-family: 'Manrope', sans-serif;">BAGRU & SANGANER</p>
          </div>
        </div>

        {% # Maker card 3 %}
        <div class="group text-left space-y-4">
          <div class="aspect-square overflow-hidden rounded-lg border border-neutral-100 bg-white">
            <img 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDXaLRyxHoXit474pzC5d4_t1i3HOfR73iLcHWuXLWculoeIwwDDCi0SMYY3jmkJZE6Y9Mh8H17UeYZWX0uyXFcbWcH0XjxuTRjczJ5SfRL7wT01E0V5GU8wFfaE_XHx05fhZwGOhU2Vbz31NBDIuK_k-3apVSjnjUK5khdXj9UxGyEsdyuF2iAVg3X7qc9lP2Li9qpIRrO1O9KFDg03nzi-B7HSHIldeYCfre8qvPNvRDVWO0m_lj_-GreNPNP73jt2NhnvQYkNbQ3" 
              alt="Designer's heritage textile swatches studio workspace" 
              width="600"
              height="600"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 filter brightness-95 group-hover:brightness-100"
            />
          </div>
          <div>
            <h3 class="text-headline-md font-medium text-[#5a000c]" style="font-family: 'Noto Serif', serif; text-transform: none;">Homegrown Visionaries</h3>
            <p class="text-[10px] font-bold text-secondary tracking-widest uppercase mt-1" style="font-family: 'Manrope', sans-serif;">NEW DELHI & MUMBAI</p>
          </div>
        </div>

      </div>

    </div>
  </section>

  {% # 4. Brand Heritage Values %}
  <section class="py-28 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      
      {% # Value 1 %}
      <div class="flex flex-col items-center text-center space-y-5 group">
        <div class="w-16 h-16 flex items-center justify-center border border-neutral-200 rounded-full group-hover:bg-[#5a000c] group-hover:text-white transition-all duration-300">
          <span class="material-symbols-outlined text-[26px]">verified</span>
        </div>
        <h4 class="text-headline-md font-medium text-[#5a000c]" style="font-family: 'Noto Serif', serif; text-transform: none;">
          Uncompromising Quality
        </h4>
        <p class="text-body-md text-secondary leading-relaxed font-light max-w-xs" style="font-family: 'Manrope', sans-serif;">
          Every thread is inspected, every stitch accounted for. We curate only pieces that meet the highest standards of artisanal excellence.
        </p>
      </div>

      {% # Value 2 %}
      <div class="flex flex-col items-center text-center space-y-5 group">
        <div class="w-16 h-16 flex items-center justify-center border border-neutral-200 rounded-full group-hover:bg-[#5a000c] group-hover:text-white transition-all duration-300">
          <span class="material-symbols-outlined text-[26px]">history_edu</span>
        </div>
        <h4 class="text-headline-md font-medium text-[#5a000c]" style="font-family: 'Noto Serif', serif; text-transform: none;">
          Living Heritage
        </h4>
        <p class="text-body-md text-secondary leading-relaxed font-light max-w-xs" style="font-family: 'Manrope', sans-serif;">
          We don't just sell clothes; we preserve living histories. Our collections are contemporary translations of ancient Indian soul.
        </p>
      </div>

      {% # Value 3 %}
      <div class="flex flex-col items-center text-center space-y-5 group">
        <div class="w-16 h-16 flex items-center justify-center border border-neutral-200 rounded-full group-hover:bg-[#5a000c] group-hover:text-white transition-all duration-300">
          <span class="material-symbols-outlined text-[26px]">eco</span>
        </div>
        <h4 class="text-headline-md font-medium text-[#5a000c]" style="font-family: 'Noto Serif', serif; text-transform: none;">
          Sustainable Path
        </h4>
        <p class="text-body-md text-secondary leading-relaxed font-light max-w-xs" style="font-family: 'Manrope', sans-serif;">
          Ethical sourcing and slow fashion are at our core. We believe in creations that respect both the creator and the environment.
        </p>
      </div>

    </div>
  </section>

  {% # 5. Asymmetric CTA Block %}
  <section class="mb-24 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="bg-[#5a000c] text-white p-12 md:p-20 rounded-xl flex flex-col md:flex-row justify-between items-center gap-12 relative overflow-hidden text-left border border-[#5a000c]">
      
      <div class="relative z-10 max-w-xl">
        <h2 class="text-headline-lg md:text-[38px] font-normal text-white mb-4 leading-tight" style="font-family: 'Noto Serif', serif; text-transform: none;">
          Discover the Thread of Tradition
        </h2>
        <p class="text-body-md md:text-body-lg text-white/90 mb-8 font-light" style="font-family: 'Manrope', sans-serif;">
          Experience the curation of India's most talented homegrown designers.
        </p>
        <a 
          href="/collections/all" 
          class="inline-block bg-white text-[#5a000c] px-10 py-4 font-bold text-[12px] uppercase tracking-widest hover:bg-[#ffdad8] hover:text-[#5a000c] transition-colors rounded-lg shadow-sm"
          style="font-family: 'Manrope', sans-serif;"
        >
          Shop Collections
        </a>
      </div>

      {% # Subtle radial backdrop styling overlay %}
      <div class="absolute right-0 top-0 h-full w-1/3 opacity-[0.04] pointer-events-none">
        <div class="w-full h-full" style="background-image: radial-gradient(circle at 2px 2px, white 2px, transparent 0); background-size: 24px 24px;"></div>
      </div>
      
    </div>
  </section>

</section>
